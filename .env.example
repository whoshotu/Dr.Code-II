# DR.CODE-v2 Environment Configuration
# Copy this file to .env and fill in your values
#
# Judge-Ready mode: Uses SQLite natively.

# =============================================================================
# DATABASE
# =============================================================================

# SQLite (default, no external database needed)
DB_TYPE=sqlite

# =============================================================================
# AI PROVIDER (required for LLM analysis)
# =============================================================================
# Ollama (local) — default
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5-coder:7b

# Alternative providers (set in Settings UI):
#   LM Studio: http://localhost:1234/v1
#   OpenAI-compatible: https://api.openai.com/v1

# =============================================================================
# CORS (required)
# =============================================================================
# Frontend URL(s), comma-separated
CORS_ORIGINS=http://localhost:3001

# =============================================================================
# FRONTEND (required — for Create React App)
# =============================================================================
# Backend API URL — used by the frontend to locate the API
# REACT_APP_BACKEND_URL=http://localhost:8002

# =============================================================================
# ENCRYPTION (optional — auto-generated on first run if not set)
# =============================================================================
# SECRET_KEY=your-secret-key-here

# =============================================================================
# GITHUB INTEGRATION (optional — for PR webhook reviews)
# =============================================================================
# Generate PAT at: https://github.com/settings/tokens
# Required scopes: repo, pull_requests:write
# GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Webhook HMAC secret (optional — enables signature verification)
# GITHUB_WEBHOOK_SECRET=your-webhook-secret
